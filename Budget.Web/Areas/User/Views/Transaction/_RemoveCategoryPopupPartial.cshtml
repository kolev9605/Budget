@model CategoriesViewModel

@inject IHtmlLocalizer<SharedResources> Resources

<div class="modal fade" id="@HtmlId.RemoveCategoryPopup.ToHtmlString()" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">@Resources["RemoveCategory"]</h4>
            </div>
            <form method="post" asp-controller="Category" asp-action="Remove">
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6 col-xs-6">
                            <div class="form-group">
                                <label asp-for="Categories"></label>
                                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-control">
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="submit" class="btn btn-default">@Resources["Remove"]</button>
                        <button type="button" class="btn btn-default" data-dismiss="modal">@Resources["Close"]</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
