@model IEnumerable<TransactionDataViewModel>

@inject IHtmlLocalizer<SharedResources> Resources

<div class="modal fade" id="@HtmlId.TransactionDetailsPopup.ToHtmlString()" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">@Resources["Details"]</h4>
            </div>
                <div class="modal-body">
                    <table class="table table-hover table-striped">
                        <thead>
                            <tr>
                                <th>@Resources["Date"]</th>
                                <th>@Resources["Amount"]</th>
                                <th>@Resources["CategoryName"]</th>
                                <th>@Resources["Description"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var transactionData in Model)
                            {
                                <tr>
                                    <td>@transactionData.Date.ToLocalTime().ToString()</td>
                                    <td>@transactionData.Amount</td>
                                    <td>@transactionData.CategoryName</td>
                                    <td>@transactionData.Description</td>
                                    <td>
                                        <a asp-controller="Transaction"
                                           asp-action="DeleteTransaction"
                                           asp-route-id="@transactionData.Id"
                                           asp-route-categoryId="@transactionData.CategoryId">
                                            <i class="fa fa-times" aria-hidden="true"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">@Resources["Close"]</button>
                </div>
        </div>
    </div>
</div>
