@model IEnumerable<TransactionDataViewModel>

<div class="modal fade" id="@HtmlId.TransactionDetailsPopup.ToHtmlString()" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">Details</h4>
            </div>
                <div class="modal-body">
                    <table class="table table-hover table-striped">
                        <thead>
                            <tr>
                                <th>@nameof(TransactionDataViewModel.Date)</th>
                                <th>@nameof(TransactionDataViewModel.Amount)</th>
                                <th>@nameof(TransactionDataViewModel.CategoryName)</th>
                                <th>@nameof(TransactionDataViewModel.Description)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var transactionData in Model)
                            {
                                <tr>
                                    <td>@transactionData.Date.ToLocalTime().ToString()</td>
                                    <td>@transactionData.Amount</td>
                                    <td>@transactionData.CategoryName</td>
                                    <td>@transactionData.Description</td>                                    
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-dismiss="modal">Close</button>
                </div>

        </div>
    </div>
</div>
