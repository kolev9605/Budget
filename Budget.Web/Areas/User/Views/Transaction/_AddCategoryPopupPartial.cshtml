@model AddCategoryViewModel

@inject IHtmlLocalizer<SharedResources> Resources

<div class="modal fade" id="@HtmlId.AddCategoryPopup.ToHtmlString()" role="dialog">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal">&times;</button>
                <h4 class="modal-title">@Resources["AddCategory"]</h4>
            </div>
            <form method="post" asp-controller="Category" asp-action="Add">

                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Name"></label>
                                <input asp-for="Name" class="form-control" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="TransactionTypes"></label>
                                <select asp-for="TransactionTypeId" asp-items="Model.TransactionTypes" class="form-control">
                                    <option>@Resources["SelectTransactionType"]</option>
                                </select>
                                <span asp-validation-for="TransactionTypeId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-default">@Resources["Add"]</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal">@Resources["Close"]</button>
                </div>
            </form>

        </div>
    </div>
</div>
