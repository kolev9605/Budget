@using Microsoft.AspNetCore.Identity
@using Budget.Web.Areas.User.ViewModels.Account

@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@inject IHtmlLocalizer<SharedResources> Resources

@if (SignInManager.IsSignedIn(User))
{
    <form asp-area="User" asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" class="navbar-right">
        <ul class="nav navbar-nav navbar-right">
            <li>
                <a asp-area="User" asp-controller="Manage" asp-action="Index" title="Manage">@Resources["Hello"] @UserManager.GetUserName(User)!</a>
            </li>
            <li>
                <button type="submit" class="btn btn-link navbar-btn navbar-link">@Resources["Logout"]</button>
            </li>
        </ul>
    </form>
}
else
{
    <ul class="nav navbar-nav navbar-right">
        <li><a asp-area="User" asp-controller="Account" asp-action="Register"><i class="fa fa-user-plus" aria-hidden="true"></i> @Resources["Register"]</a></li>
        <li><a asp-area="User" asp-controller="Account" asp-action="Login"><i class="fa fa-user" aria-hidden="true"></i> @Resources["Login"]</a></li>
    </ul>
}
